{
  "name": "mandalay-land",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti:3000 | xargs kill -9 2>/dev/null; rm -rf .next && next dev",
    "clean": "lsof -ti:3000 | xargs kill -9 2>/dev/null; rm -rf .next",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "seed": "node prisma/seed.js",
    "db:setup": "prisma migrate dev --name init"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "next": "14.2.5",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "prisma": "^5.18.0",
    "tailwindcss": "^4.3.1"
  }
}
